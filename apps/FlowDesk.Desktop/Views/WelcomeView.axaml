<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowDesk.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="FlowDesk.Desktop.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="32">
        
        <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to FlowDesk" 
                       FontSize="{StaticResource FontSizeDisplay}" 
                       FontWeight="{StaticResource FontWeightSemiBold}" 
                       Foreground="{DynamicResource InkBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Choose how you want to use FlowDesk." 
                       FontSize="{StaticResource FontSizeTitle}" 
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid ColumnDefinitions="320, 320, 320" RowDefinitions="Auto" Margin="0,48,0,0">
            <!-- Private Workspace Card -->
            <Border Grid.Column="0" Margin="12" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Private Workspace" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                    <TextBlock Text="Use FlowDesk only on this device. Best for private work and solo projects." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="{StaticResource FontSizeBody}" MinHeight="60"/>
                    <Button Content="Choose Private" Command="{Binding ChoosePrivateModeCommand}" Classes="Primary" HorizontalAlignment="Stretch" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Local Workspace Card -->
            <Border Grid.Column="1" Margin="12" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Local Workspace" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                    <TextBlock Text="Share FlowDesk with people on the same office network. Best for teams working in one place." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="{StaticResource FontSizeBody}" MinHeight="60"/>
                    <Button Content="Coming Soon" IsEnabled="False" Classes="Secondary" HorizontalAlignment="Stretch" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Server Workspace Card -->
            <Border Grid.Column="2" Margin="12" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Server Workspace" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                    <TextBlock Text="Connect to a self-hosted FlowDesk server. Best for companies and remote teams." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="{StaticResource FontSizeBody}" MinHeight="60"/>
                    <Button Content="Coming Soon" IsEnabled="False" Classes="Secondary" HorizontalAlignment="Stretch" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

    </StackPanel>

</UserControl>
