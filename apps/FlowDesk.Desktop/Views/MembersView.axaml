<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlowDesk.Desktop.ViewModels"
             x:Class="FlowDesk.Desktop.Views.MembersView"
             x:DataType="vm:MembersViewModel">

    <StackPanel Margin="{StaticResource Spacing8}" Spacing="24">
        <TextBlock Text="Members" FontSize="{StaticResource FontSizePageTitle}" FontWeight="{StaticResource FontWeightSemiBold}" Foreground="{DynamicResource InkBrush}"/>

        <!-- Table Header -->
        <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Padding="16,8">
            <Grid ColumnDefinitions="2*, 1*, 1*">
                <TextBlock Grid.Column="0" Text="Name" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Grid.Column="1" Text="Role" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Grid.Column="2" Text="Workspace Mode" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
            </Grid>
        </Border>

        <!-- Current User (Owner) -->
        <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid ColumnDefinitions="2*, 1*, 1*">
                <TextBlock Grid.Column="0" Text="{Binding UserName}" FontWeight="{StaticResource FontWeightMedium}" VerticalAlignment="Center" Foreground="{DynamicResource InkBrush}"/>
                <Border Grid.Column="1" Background="{DynamicResource PrimarySoftBrush}" CornerRadius="{StaticResource RadiusXs}" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Owner" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="Private" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Info Note -->
        <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="{StaticResource Spacing4}" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="ℹ️" VerticalAlignment="Center"/>
                <TextBlock Text="In Private Workspace mode, you are the sole member and owner." Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
