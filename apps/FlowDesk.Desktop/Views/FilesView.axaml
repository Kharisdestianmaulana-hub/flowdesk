<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlowDesk.Desktop.ViewModels"
             x:Class="FlowDesk.Desktop.Views.FilesView"
             x:DataType="vm:FilesViewModel">

    <Grid>
        <StackPanel Margin="{StaticResource Spacing8}" Spacing="24">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBlock Grid.Column="0" Text="Files" FontSize="{StaticResource FontSizePageTitle}" FontWeight="{StaticResource FontWeightSemiBold}" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery}" Width="250" Classes="FlowDesk" PlaceholderText="Search files..." Margin="0,0,16,0" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Import File" Command="{Binding ImportFileCommand}" Classes="Primary" VerticalAlignment="Center"/>
            </Grid>

            <!-- Table Header -->
            <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Padding="16,8">
                <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto">
                    <TextBlock Grid.Column="0" Text="Name" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="Type" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="2" Text="Size" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="3" Text="Added On" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="4" Text="Actions" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource TextMutedBrush}" Width="150" TextAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Files List -->
            <ItemsControl ItemsSource="{Binding FilteredFiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                            <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="{StaticResource FontWeightMedium}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeBytes}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding CreatedAt, StringFormat='MMM dd, yyyy'}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Edit" Command="{Binding $parent[ItemsControl].((vm:FilesViewModel)DataContext).OpenEditCommand}" CommandParameter="{Binding}" Classes="Secondary" Padding="8,4" FontSize="{StaticResource FontSizeCaption}"/>
                                    <Button Content="Reveal" Command="{Binding $parent[ItemsControl].((vm:FilesViewModel)DataContext).RevealInFolderCommand}" CommandParameter="{Binding}" Classes="Secondary" Padding="8,4" FontSize="{StaticResource FontSizeCaption}"/>
                                    <Button Content="Delete" Command="{Binding $parent[ItemsControl].((vm:FilesViewModel)DataContext).ConfirmDeleteCommand}" CommandParameter="{Binding}" Classes="Secondary" Foreground="Red" Padding="8,4" FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}" IsVisible="{Binding IsEmpty}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Margin="0,48">
                    <PathIcon Data="M14,2H6C4.89,2 4,2.89 4,4V20C4,21.11 4.89,22 6,22H18C19.11,22 20,21.11 20,20V8L14,2M13,9V3.5L18.5,9H13Z" Foreground="{DynamicResource TextMutedBrush}" Width="48" Height="48" Opacity="0.5" Margin="0,0,0,8"/>
                    <TextBlock Text="No files imported yet." FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightSemiBold}" Foreground="{DynamicResource InkBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click Import File to add resources to your workspace." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Delete Confirmation Modal -->
        <Grid Background="#66000000" IsVisible="{Binding IsDeleteConfirmOpen}">
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 8 32 0 #33000000">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Delete File?" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightBold}" Foreground="{DynamicResource InkBrush}"/>
                        <TextBlock Text="Are you sure you want to delete this file from FlowDesk? The original file (if not moved) will remain unharmed." Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <Grid ColumnDefinitions="*, *">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelDeleteCommand}" Classes="Secondary" Margin="0,0,8,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Delete" Command="{Binding ExecuteDeleteCommand}" Classes="Primary" Background="Red" BorderBrush="Red" Margin="8,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit File Modal -->
        <Grid Background="#66000000" IsVisible="{Binding IsEditOpen}">
            <Border Background="{DynamicResource SurfaceBrush}" Width="400" HorizontalAlignment="Right" BoxShadow="-4 0 20 0 #33000000">
                <StackPanel Margin="{StaticResource Spacing6}" Spacing="24">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0" Text="Edit File" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightBold}" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Close" Command="{Binding CancelEditCommand}" Classes="Secondary" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"/>
                    </Grid>

                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Name" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                            <TextBox Text="{Binding EditFileName}" Classes="FlowDesk"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Project" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                            <ComboBox ItemsSource="{Binding Projects}" SelectedValue="{Binding EditProjectId}" SelectedValueBinding="{Binding Id}" HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Button Content="Save Changes" Command="{Binding SaveFileDetailsCommand}" Classes="Primary" HorizontalAlignment="Right" Margin="0,16,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error Dialog Modal -->
        <Grid Background="#66000000" IsVisible="{Binding IsErrorOpen}" ZIndex="200">
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 8 32 0 #33000000">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="8">
                        <TextBlock Text="File Not Found" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightBold}" Foreground="{DynamicResource InkBrush}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <Button Content="Close" Command="{Binding CloseErrorCommand}" Classes="Secondary" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
