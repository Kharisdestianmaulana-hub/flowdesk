<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlowDesk.Desktop.ViewModels"
             x:Class="FlowDesk.Desktop.Views.PlaceholderView"
             x:DataType="vm:PlaceholderViewModel">

    <StackPanel Margin="{StaticResource Spacing8}" Spacing="24">
        <TextBlock Text="{Binding ModuleName}" FontSize="{StaticResource FontSizePageTitle}" FontWeight="{StaticResource FontWeightSemiBold}" Foreground="{DynamicResource InkBrush}"/>

        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Margin="0,48">
                <TextBlock Text="Coming Soon" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightSemiBold}" HorizontalAlignment="Center"/>
                <TextBlock Text="This module is under construction." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
