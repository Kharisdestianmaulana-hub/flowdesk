<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlowDesk.Desktop.ViewModels"
             x:Class="FlowDesk.Desktop.Views.ProjectDetailView"
             x:DataType="vm:ProjectDetailViewModel">

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="{StaticResource Spacing8}" Spacing="24">
                <!-- Header & Edit -->
                <StackPanel Spacing="16">
                    <Button Content="← Back to Projects" Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Foreground="{DynamicResource TextMutedBrush}"/>
                    
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Project Name" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                                <TextBox Text="{Binding EditName}" Classes="FlowDesk"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Description" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                                <TextBox Text="{Binding EditDescription}" Classes="FlowDesk" AcceptsReturn="True" Height="80"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*, *">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,8,0">
                                    <TextBlock Text="Status" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                                    <TextBox Text="{Binding EditStatus}" Classes="FlowDesk" ToolTip.Tip="Enter status (e.g., Planning, Active, Completed, Paused)"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
                                    <TextBlock Text="Type" FontWeight="{StaticResource FontWeightMedium}" FontSize="{StaticResource FontSizeCaption}"/>
                                    <TextBox Text="{Binding EditType}" Classes="FlowDesk" ToolTip.Tip="Enter type (e.g., General, Software, Design)"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Archive Project" Command="{Binding ArchiveProjectCommand}" Classes="Secondary"/>
                                    <Button Content="Delete Project" Command="{Binding ConfirmDeleteCommand}" Classes="Secondary" Foreground="Red"/>
                                </StackPanel>
                                <Button Content="Save Details" Command="{Binding SaveProjectDetailsCommand}" Classes="Primary"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid ColumnDefinitions="2*, 1*" Margin="0,16,0,0">
                    <!-- Left Column -->
                    <StackPanel Grid.Column="0" Spacing="24" Margin="0,0,24,0">
                        <!-- Tasks -->
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing5}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Linked Tasks" FontWeight="{StaticResource FontWeightSemiBold}" FontSize="{StaticResource FontSizeSectionTitle}"/>
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" Margin="0,0,0,8"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No tasks linked yet." Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding !Tasks.Count}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Docs -->
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing5}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Linked Docs" FontWeight="{StaticResource FontWeightSemiBold}" FontSize="{StaticResource FontSizeSectionTitle}"/>
                                <ItemsControl ItemsSource="{Binding Documents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" Margin="0,0,0,8"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No docs linked yet." Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding !Documents.Count}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="1" Spacing="24">
                        <!-- Files -->
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing5}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Linked Files" FontWeight="{StaticResource FontWeightSemiBold}" FontSize="{StaticResource FontSizeSectionTitle}"/>
                                <ItemsControl ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Margin="0,0,0,8"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No files linked yet." Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding !Files.Count}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Activity Log -->
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing5}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Activity" FontWeight="{StaticResource FontWeightSemiBold}" FontSize="{StaticResource FontSizeSectionTitle}"/>
                                <ItemsControl ItemsSource="{Binding ActivityLogs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='MMM dd HH:mm'}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding ActorName}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{DynamicResource InkBrush}"/>
                                                        <TextBlock Text="{Binding Action}" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="{Binding TargetType}" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No activity yet." Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding !ActivityLogs.Count}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Delete Confirmation Modal -->
        <Grid Background="#66000000" IsVisible="{Binding IsDeleteConfirmOpen}" ZIndex="100">
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource Spacing6}" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 8 32 0 #33000000">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Delete this project?" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightBold}" Foreground="{DynamicResource InkBrush}"/>
                        <TextBlock Text="This action cannot be undone. All linked tasks, docs, and files will lose their project association." Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                        <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" Classes="Secondary"/>
                        <Button Content="Delete" Command="{Binding ExecuteDeleteCommand}" Classes="Primary" Background="Red"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
