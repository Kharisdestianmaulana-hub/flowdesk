<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FlowDesk.Desktop.App"
             xmlns:local="using:FlowDesk.Desktop"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FlowDesk.Desktop/Resources/Colors.axaml"/>
                <ResourceInclude Source="avares://FlowDesk.Desktop/Resources/Typography.axaml"/>
                <ResourceInclude Source="avares://FlowDesk.Desktop/Resources/Spacing.axaml"/>
                <ResourceInclude Source="avares://FlowDesk.Desktop/Resources/Themes/Light.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <StreamGeometry x:Key="CheckmarkIcon">M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</StreamGeometry>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://FlowDesk.Desktop/Resources/Controls.axaml"/>
    </Application.Styles>
</Application>