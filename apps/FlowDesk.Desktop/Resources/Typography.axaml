<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Font Family -->
    <FontFamily x:Key="FlowDeskFont">system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, "Noto Sans", sans-serif</FontFamily>

    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeDisplay">32</x:Double>
    <x:Double x:Key="FontSizePageTitle">26</x:Double>
    <x:Double x:Key="FontSizeTitle">22</x:Double>
    <x:Double x:Key="FontSizeSectionTitle">17</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeUI">13</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeMicro">11</x:Double>
    <x:Double x:Key="FontSizeButton">13</x:Double>

    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightRegular">Regular</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
</ResourceDictionary>
