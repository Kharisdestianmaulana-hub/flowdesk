<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Primary Button Style -->
    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="{StaticResource FlowDeskFont}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeButton}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.Primary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.Primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>

    <!-- Secondary Button Style -->
    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="{StaticResource FlowDeskFont}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeButton}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.Secondary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>
    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- Base TextBox -->
    <Style Selector="TextBox.FlowDesk">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontFamily" Value="{StaticResource FlowDeskFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>
    <Style Selector="TextBox.FlowDesk /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style Selector="TextBox.FlowDesk:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
    </Style>
    <Style Selector="TextBox.FlowDesk:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FocusBrush}"/>
    </Style>
</Styles>
